#!/bin/csh -f

source $MODULESHOME/init/csh
source ${PWD}/../../../../modulefiles/fv3gfs/fre-nctools.s4

ifort -o filter_topo -I${NETCDF_INC} -fltconsistency -fno-alias -stack_temps -safe_cray_ptr -ftz -assume byterecl -g -O2 -i4 -real_size 64 -traceback filter_topo.F90 -L${NETCDF_LIB} -L${SSEC_HDF5_LIB} -lnetcdf -lnetcdff -lhdf5_hl -lhdf5
